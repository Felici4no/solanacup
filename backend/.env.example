# Network: devnet | mainnet  (RPC, program, mint, JWT host and activation MUST match)
NETWORK=devnet

# Solana RPC (defaults to the public cluster endpoint of NETWORK)
# RPC_URL=https://api.devnet.solana.com

# Backend wallet — pays devnet fees, signs the TxLINE subscribe tx and the
# activation message (MUST be the same wallet), and is the VEZ mint authority.
# Either a path to a JSON keypair file (solana-keygen format):
ANCHOR_WALLET=./.keys/backend-wallet.json
# ...or the JSON array itself:
# WALLET_SECRET=[1,2,3,...]

# TxLINE free World Cup tier: 1 = 60s delay (mainnet) / devnet sampling 0.
# 12 = real-time World Cup (mainnet).
TXLINE_SERVICE_LEVEL=1
# Multiples of 4 only (per docs)
TXLINE_WEEKS=4

# Reuse an already-activated API token (skips on-chain subscribe on boot).
# Cached automatically at .txline/token.json after first activation.
# TXLINE_API_TOKEN=

# G3B fan token mint (created automatically on first boot if unset)
# G3B_MINT=

PORT=8787
